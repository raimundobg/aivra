{
  "name": "tablero-sence-api",
  "version": "1.0.0",
  "description": "Tablero SENCE - Sistema de datos operacionales con DynamoDB",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "npx ts-node scripts/localServer.ts",
    "dev:server": "npx ts-node scripts/localServer.ts",
    "test:api": "npx ts-node scripts/testApi.ts",
    "test:workflow": "npx ts-node scripts/workflowTest.ts",
    "migrate": "npx ts-node scripts/migrateExcelToDynamo.ts",
    "migrate:dry-run": "npx ts-node scripts/migrateExcelToDynamo.ts --dry-run",
    "deploy": "cd lambda/tablero_sence_api && serverless deploy --stage dev",
    "deploy:prod": "cd lambda/tablero_sence_api && serverless deploy --stage prod",
    "remove": "cd lambda/tablero_sence_api && serverless remove --stage dev",
    "remove:prod": "cd lambda/tablero_sence_api && serverless remove --stage prod",
    "offline": "cd lambda/tablero_sence_api && serverless offline",
    "logs": "cd lambda/tablero_sence_api && serverless logs -f api --stage dev --tail",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raioumine/umine-ui-core-operaciones.git"
  },
  "author": "Raimundo Burchardt",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "axios": "^1.6.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/node": "^20.11.0",
    "serverless": "^3.38.0",
    "serverless-offline": "^13.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
