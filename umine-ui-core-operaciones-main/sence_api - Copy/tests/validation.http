@baseUrl = http://localhost:3000/dev

### 1. Start Session (Sence calls OTEC)
POST {{baseUrl}}/sence/start-session
Content-Type: application/json

< ./mocks/start-session.json

### 2. End Session (Sence calls OTEC)
POST {{baseUrl}}/sence/end-session
Content-Type: application/json

< ./mocks/end-session.json

### 3. Sync Progress (OTEC calls Sence)
# Note: This will attempt to call the real Sence API if not mocked!
POST {{baseUrl}}/sence/sync
Content-Type: application/json

< ./mocks/sync-progress.json
