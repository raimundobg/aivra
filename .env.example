# ============================================
# BITETRACK - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo como .env y completa los valores

# === EMAIL (Gmail) ===
# Para obtener MAIL_PASSWORD:
# 1. Habilita verificacion en 2 pasos: https://myaccount.google.com/security
# 2. Crea App Password: https://myaccount.google.com/apppasswords
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# === IA (Groq - Gratis) ===
# Obtener API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# === BASE DE DATOS (Opcional - para produccion) ===
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
